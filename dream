<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>解梦日记</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; min-height: 100vh; }
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #f1f1f1; }
::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 3px; }
.mood-btn { transition: all 0.2s ease; }
.mood-btn:hover { transform: scale(1.1); }
.mood-btn.active { transform: scale(1.2); }
.fade-enter-active, .fade-leave-active { transition: opacity 0.2s ease; }
.fade-enter-from, .fade-leave-to { opacity: 0; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.loading-spinner { animation: spin 1s linear infinite; }
.toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%); padding: 12px 24px; border-radius: 8px; color: white; font-size: 14px; z-index: 9999; }
.toast.success { background-color: #28a745; }
.toast.error { background-color: #dc3545; }
</style>
</head>
<body>
<div id="app"></div>
<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<script>
const { createApp, ref, computed, onMounted, watch, nextTick } = Vue;
const STORAGE_KEY = 'dream_diary_data';
const MOODS = {
  happy: { label: '开心', emoji: '😊', color: '#FFD700' },
  calm: { label: '平静', emoji: '😌', color: '#87CEEB' },
  sad: { label: '悲伤', emoji: '😢', color: '#9370DB' },
  scared: { label: '害怕', emoji: '😨', color: '#A9A9A9' },
  angry: { label: '生气', emoji: '😠', color: '#FF6347' },
  confused: { label: '困惑', emoji: '🤔', color: '#90EE90' }
};
const getAllData = () => {
  try { const data = localStorage.getItem(STORAGE_KEY); return data ? JSON.parse(data) : { records: [] }; }
  catch { return { records: [] }; }
};
const saveAllData = (data) => { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); };
const getRecords = () => getAllData().records || [];
const saveRecord = (record) => {
  const data = getAllData();
  const idx = data.records.findIndex(r => r.id === record.id);
  if (idx >= 0) data.records[idx] = { ...record, updatedAt: Date.now() };
  else data.records.unshift({ ...record, createdAt: Date.now(), updatedAt: Date.now() });
  saveAllData(data);
};
const deleteRecord = (id) => {
  const data = getAllData();
  data.records = data.records.filter(r => r.id !== id);
  saveAllData(data);
};
const generateId = () => Date.now().toString(36) + Math.random().toString(36).substr(2);
const getMoodEmoji = (mood) => MOODS[mood]?.emoji || '😐';
const getMoodColor = (mood) => MOODS[mood]?.color || '#999999';
const getMoodLabel = (mood) => MOODS[mood]?.label || mood;
const exportToTxt = () => {
  const data = getAllData();
  const txt = data.records.map(r => `=== ${r.date} ===\n心情：${getMoodLabel(r.mood)}\n梦境：${r.content}\n${r.interpretation ? `\n解梦结果：\n传统解释：${r.interpretation.traditional}\n心理学分析：${r.interpretation.psychological}\n行动建议：${r.interpretation.suggestion}` : ''}\n\n`).join('');
  const blob = new Blob([txt], { type: 'text/plain;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const link = document.createElement('a');
  link.href = url;
  link.download = `dream_diary_${new Date().toISOString().split('T')[0]}.txt`;
  link.click();
  URL.revokeObjectURL(url);
};
const importFromTxt = (content) => {
  try {
    const records = [];
    const sections = content.split('===');
    for (let i = 1; i < sections.length; i++) {
      const section = sections[i].trim();
      if (!section) continue;
      const lines = section.split('\n');
      const date = lines[0]?.trim();
      const moodMatch = lines.find(l => l.includes('心情：'));
      const contentMatch = lines.find(l => l.includes('梦境：'));
      if (!date || !moodMatch || !contentMatch) continue;
      const moodLabel = moodMatch.replace('心情：', '').trim();
      const moodKey = Object.keys(MOODS).find(k => MOODS[k].label === moodLabel) || 'calm';
      const contentText = contentMatch.replace('梦境：', '').trim();
      const tradMatch = content.match(new RegExp(`=== ${date} ===[\\s\\S]*?传统解释：([\\s\\S]*?)(?=\\n心理学分析：|$)`));
      const psyMatch = content.match(new RegExp(`=== ${date} ===[\\s\\S]*?心理学分析：([\\s\\S]*?)(?=\\n行动建议：|$)`));
      const sugMatch = content.match(new RegExp(`=== ${date} ===[\\s\\S]*?行动建议：([\\s\\S]*?)(?=\\n===|$)`));
      records.push({
        id: generateId(),
        date, mood: moodKey, content: contentText,
        interpretation: {
          traditional: tradMatch ? tradMatch[1].trim() : '',
          psychological: psyMatch ? psyMatch[1].trim() : '',
          suggestion: sugMatch ? sugMatch[1].trim() : ''
        },
        createdAt: Date.now(),
        updatedAt: Date.now()
      });
    }
    if (records.length > 0) {
      const data = getAllData();
      data.records = [...records, ...data.records];
      saveAllData(data);
      return { success: true, count: records.length };
    }
    return { success: false, message: '未找到有效的记录数据' };
  } catch (e) { return { success: false, message: '导入失败：' + e.message }; }
};
const clearAllData = () => { localStorage.removeItem(STORAGE_KEY); };
let puter = null;
const ensurePuter = () => {
  if (puter) return Promise.resolve(puter);
  if (window.puter) { puter = window.puter; return Promise.resolve(puter); }
  return new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.src = 'https://js.puter.com/v2/';
    script.onload = () => { puter = window.puter; resolve(puter); };
    script.onerror = reject;
    document.head.appendChild(script);
  });
};
const generateMockInterpretation = (content) => {
  return new Promise(resolve => setTimeout(() => resolve({
    traditional: `根据周公解梦，${content.includes('飞') ? '梦见飞翔代表近期运势上升，事业有成。' : '此梦预示着近期会有贵人相助，诸事顺利。'}`,
    psychological: `从心理学角度分析，这个梦境反映了你${content.includes('追逐') ? '内心对目标的追求和渴望' : '当前的情绪状态和潜意识需求'}。梦境中的元素往往是现实生活的映射。`,
    suggestion: '建议你关注自己的情绪变化，保持积极乐观的心态。如果此梦反复出现，可以尝试记录梦境细节，探索更深层的心理意义。'
  }), 1500));
};
const generateInterpretation = async (dreamContent) => {
  try {
    await ensurePuter();
    let user = null;
    try { user = await puter.auth.getUser(); } catch {}
    if (!user) {
      try { await puter.auth.signIn(); } catch (e) { return generateMockInterpretation(dreamContent); }
    }
    const prompt = `请对以下梦境进行全面解读：\n\n梦境内容：${dreamContent}\n\n请从三个方面进行分析：\n1. 传统周公解梦解释：基于中国传统周公解梦的角度分析梦境中出现的元素象征意义\n2. 心理学角度分析：从现代心理学的角度分析梦境可能反映的潜意识、情绪状态或心理需求\n3. 行动建议：基于以上分析，给出具体的行动建议帮助用户理解和应对\n\n请确保回答准确、专业且易于理解。`;
    const response = await puter.ai.chat(prompt);
    const result = typeof response === 'string' ? response : (response?.message?.content || response?.toString() || '');
    const tradMatch = result.match(/1[．.、]?传统周公解梦解释[：:]?([\s\S]*?)(?=\n2[．.、]|$)/);
    const psyMatch = result.match(/2[．.、]?心理学角度分析[：:]?([\s\S]*?)(?=\n3[．.、]|$)/);
    const sugMatch = result.match(/3[．.、]?行动建议[：:]?([\s\S]*)/);
    return {
      traditional: tradMatch ? tradMatch[1].trim() : result,
      psychological: psyMatch ? psyMatch[1].trim() : '',
      suggestion: sugMatch ? sugMatch[1].trim() : ''
    };
  } catch (e) {
    console.error('AI 解梦失败:', e);
    return generateMockInterpretation(dreamContent);
  }
};
const showToast = (message, type = 'success') => {
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), type === 'error' ? 3000 : 2000);
};
const HomePage = {
  setup() {
    const moods = MOODS;
    const dreamContent = ref('');
    const selectedMood = ref('calm');
    const selectedDate = ref(new Date().toISOString().split('T')[0]);
    const records = ref([]);
    const isGenerating = ref(false);
    const chartCanvas = ref(null);
    let chartInstance = null;
    const showDetailModal = ref(false);
    const selectedRecord = ref(null);
    const showEditModal = ref(false);
    const editContent = ref('');
    const editMood = ref('calm');
    const editDate = ref('');
    const showDeleteConfirm = ref(false);
    const showInterpretationModal = ref(false);
    const interpretationResult = ref({ traditional: '', psychological: '', suggestion: '' });
    const activeInterpretationTab = ref('traditional');
    const canSave = computed(() => dreamContent.value.trim() && selectedMood.value);
    const miniCalendarData = computed(() => {
      const data = [];
      const today = new Date();
      for (let i = 29; i >= 0; i--) {
        const date = new Date(today);
        date.setDate(date.getDate() - i);
        const dateStr = date.toISOString().split('T')[0];
        const record = records.value.find(r => r.date === dateStr);
        data.push({ date: dateStr, day: date.getDate(), mood: record?.mood || null });
      }
      return data;
    });
    const chartData = computed(() => {
      const moodValues = { happy: 5, calm: 4, confused: 3, sad: 2, scared: 1, angry: 0 };
      const data = [];
      const today = new Date();
      for (let i = 29; i >= 0; i--) {
        const date = new Date(today);
        date.setDate(date.getDate() - i);
        const dateStr = date.toISOString().split('T')[0];
        const record = records.value.find(r => r.date === dateStr);
        data.push({ date: `${date.getMonth() + 1}/${date.getDate()}`, value: record ? moodValues[record.mood] || 3 : null });
      }
      return data;
    });
    const loadRecords = () => { records.value = getRecords(); };
    const saveRecordHandler = async (withInterpretation) => {
      if (!canSave.value) return;
      const record = {
        id: generateId(),
        date: selectedDate.value,
        mood: selectedMood.value,
        content: dreamContent.value.trim(),
        interpretation: null
      };
      if (withInterpretation) {
        isGenerating.value = true;
        try {
          record.interpretation = await generateInterpretation(dreamContent.value);
          interpretationResult.value = record.interpretation;
          showInterpretationModal.value = true;
        } catch (e) { showToast('解梦失败', 'error'); }
        isGenerating.value = false;
      }
      saveRecord(record);
      loadRecords();
      dreamContent.value = '';
      selectedMood.value = 'calm';
      selectedDate.value = new Date().toISOString().split('T')[0];
      showToast(withInterpretation ? '记录并解梦成功' : '记录成功');
    };
    const showDetail = (record) => { selectedRecord.value = record; showDetailModal.value = true; };
    const closeDetailModal = () => { showDetailModal.value = false; selectedRecord.value = null; };
    const editRecord = () => {
      if (selectedRecord.value) {
        editContent.value = selectedRecord.value.content;
        editMood.value = selectedRecord.value.mood;
        editDate.value = selectedRecord.value.date;
        showEditModal.value = true;
        showDetailModal.value = false;
      }
    };
    const cancelEdit = () => { showEditModal.value = false; };
    const saveEdit = () => {
      if (!editContent.value.trim()) return;
      const updated = { ...selectedRecord.value, content: editContent.value.trim(), mood: editMood.value, date: editDate.value };
      saveRecord(updated);
      loadRecords();
      cancelEdit();
      showToast('修改成功');
    };
    const confirmDelete = () => { showDeleteConfirm.value = true; };
    const deleteRecordHandler = () => {
      if (selectedRecord.value) {
        deleteRecord(selectedRecord.value.id);
        loadRecords();
        showDeleteConfirm.value = false;
        closeDetailModal();
        showToast('删除成功');
      }
    };
    const regenerateInterpretation = async () => {
      if (selectedRecord.value) {
        isGenerating.value = true;
        const result = await generateInterpretation(selectedRecord.value.content);
        interpretationResult.value = result;
        const updated = { ...selectedRecord.value, interpretation: result };
        saveRecord(updated);
        loadRecords();
        isGenerating.value = false;
        showToast('重新生成成功');
      }
    };
    const updateChart = () => {
      if (!chartCanvas.value || chartData.value.length === 0) return;
      if (chartInstance) chartInstance.destroy();
      const ctx = chartCanvas.value.getContext('2d');
      chartInstance = new Chart(ctx, {
        type: 'line',
        data: {
          labels: chartData.value.map(d => d.date),
          datasets: [{
            label: '心情指数',
            data: chartData.value.map(d => d.value),
            borderColor: '#4A90E2',
            backgroundColor: 'rgba(74, 144, 226, 0.1)',
            fill: true, tension: 0.4, pointRadius: 4,
            pointBackgroundColor: '#4A90E2',
            pointBorderColor: '#fff', pointBorderWidth: 2,
            spanGaps: true
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: { y: { beginAtZero: true, max: 5, ticks: { stepSize: 1 } }, x: { ticks: { maxTicksLimit: 7 } } },
          plugins: { legend: { display: false } }
        }
      });
    };
    watch(chartData, () => nextTick(updateChart), { deep: true });
    onMounted(() => { loadRecords(); nextTick(updateChart); });
    return {
      moods, dreamContent, selectedMood, selectedDate, records, isGenerating, chartCanvas,
      canSave, miniCalendarData, saveRecordHandler, showDetail, showDetailModal, selectedRecord,
      closeDetailModal, editRecord, showEditModal, editContent, editMood, editDate, cancelEdit,
      saveEdit, confirmDelete, showDeleteConfirm, deleteRecordHandler,
      getMoodEmoji, getMoodColor,
      showInterpretationModal, interpretationResult, activeInterpretationTab,
      regenerateInterpretation,
      showDayDetail: (date) => { const r = records.value.find(r => r.date === date); if (r) showDetail(r); }
    };
  },
  template: `
    <div class="space-y-6">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-2">解梦日记</h1>
        <p class="text-gray-500">记录你的梦境，探索内心世界</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-sm font-medium text-gray-600 mb-3">记录你的梦境</h2>
        <textarea v-model="dreamContent" placeholder="输入梦境内容..." rows="4"
          class="w-full p-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 resize-none"
          maxlength="500"></textarea>
        <div class="text-right text-xs text-gray-400 mt-1">{{ dreamContent.length }}/500</div>
        <div class="flex gap-2 mt-4 justify-between">
          <button v-for="(mood, key) in moods" :key="key" @click="selectedMood = key"
            :class="['mood-btn flex items-center justify-center w-12 h-12 rounded-full',
              selectedMood === key ? 'bg-gray-100 ring-2 ring-blue-400' : 'hover:bg-gray-50']"
            :title="mood.label">
            <span class="text-2xl">{{ mood.emoji }}</span>
          </button>
        </div>
        <div class="flex items-center justify-between mt-4 flex-wrap gap-2">
          <input type="date" v-model="selectedDate"
            class="px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300" />
          <div class="flex gap-2">
            <button @click="saveRecordHandler(false)" :disabled="!canSave"
              class="px-4 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors disabled:opacity-50">仅记录</button>
            <button @click="saveRecordHandler(true)" :disabled="!canSave || isGenerating"
              class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors disabled:opacity-50 flex items-center">
              <span v-if="isGenerating" class="loading-spinner w-4 h-4 border-2 border-white border-t-transparent rounded-full mr-2"></span>
              {{ isGenerating ? '解梦中...' : '记录并解梦' }}
            </button>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-sm font-medium text-gray-600 mb-3">最近30天心情日历</h2>
        <div v-if="miniCalendarData.length > 0" class="grid grid-cols-7 gap-1">
          <div v-for="day in miniCalendarData" :key="day.date" class="text-center">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-full text-xs cursor-pointer"
              :style="day.mood ? { backgroundColor: getMoodColor(day.mood) + '40' } : {}"
              @click="showDayDetail(day.date)">
              <div class="flex flex-col items-center">
                <span>{{ day.day }}</span>
                <span v-if="day.mood" class="text-sm leading-none">{{ getMoodEmoji(day.mood) }}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-sm font-medium text-gray-600 mb-3">近30天心情趋势</h2>
        <div class="h-40"><canvas ref="chartCanvas"></canvas></div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-sm font-medium text-gray-600 mb-3">历史记录</h2>
        <div v-if="records.length > 0" class="space-y-3">
          <div v-for="record in records" :key="record.id" @click="showDetail(record)"
            class="p-3 rounded-lg border border-gray-100 hover:bg-gray-50 cursor-pointer transition-colors">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-gray-800">{{ record.date }}</span>
              <span class="text-lg">{{ getMoodEmoji(record.mood) }}</span>
            </div>
            <p class="text-sm text-gray-600 line-clamp-2">{{ record.content }}</p>
          </div>
        </div>
        <div v-else class="text-center text-gray-400 py-8">暂无梦境记录</div>
      </div>
      <div v-if="showDetailModal" class="fixed inset-0 bg-black/50 z-50 flex items-end md:items-center justify-center" @click.self="closeDetailModal">
        <div class="bg-white w-full md:w-[500px] md:rounded-2xl rounded-t-2xl max-h-[80vh] overflow-hidden">
          <div class="flex justify-between items-center p-4 border-b">
            <button @click="closeDetailModal" class="text-gray-400 hover:text-gray-600 text-xl">←</button>
            <h3 class="text-lg font-semibold text-gray-800">梦境详情</h3>
            <div class="w-8"></div>
          </div>
          <div class="p-4 overflow-y-auto max-h-[calc(80vh-120px)]">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xl">{{ getMoodEmoji(selectedRecord.mood) }}</span>
              <span class="text-gray-600">{{ selectedRecord.date }}</span>
            </div>
            <p class="text-gray-800 leading-relaxed mb-6 whitespace-pre-wrap">{{ selectedRecord.content }}</p>
            <div v-if="selectedRecord.interpretation && (selectedRecord.interpretation.traditional || selectedRecord.interpretation.psychological || selectedRecord.interpretation.suggestion)" class="space-y-4">
              <h4 class="font-medium text-gray-700">解梦结果</h4>
              <div v-if="selectedRecord.interpretation.traditional" class="p-3 bg-gray-50 rounded-lg">
                <h5 class="text-sm font-medium text-blue-500 mb-2">传统周公解梦解释</h5>
                <p class="text-sm text-gray-600 whitespace-pre-wrap">{{ selectedRecord.interpretation.traditional }}</p>
              </div>
              <div v-if="selectedRecord.interpretation.psychological" class="p-3 bg-gray-50 rounded-lg">
                <h5 class="text-sm font-medium text-blue-500 mb-2">心理学角度分析</h5>
                <p class="text-sm text-gray-600 whitespace-pre-wrap">{{ selectedRecord.interpretation.psychological }}</p>
              </div>
              <div v-if="selectedRecord.interpretation.suggestion" class="p-3 bg-gray-50 rounded-lg">
                <h5 class="text-sm font-medium text-blue-500 mb-2">行动建议</h5>
                <p class="text-sm text-gray-600 whitespace-pre-wrap">{{ selectedRecord.interpretation.suggestion }}</p>
              </div>
            </div>
          </div>
          <div class="flex gap-3 p-4 border-t">
            <button @click="editRecord" class="flex-1 py-2 px-4 border border-blue-500 text-blue-500 rounded-lg hover:bg-blue-50 transition-colors">编辑</button>
            <button @click="confirmDelete" class="flex-1 py-2 px-4 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors">删除</button>
          </div>
        </div>
      </div>
      <div v-if="showEditModal" class="fixed inset-0 bg-black/50 z-50 flex items-end md:items-center justify-center" @click.self="cancelEdit">
        <div class="bg-white w-full md:w-[500px] md:rounded-2xl rounded-t-2xl max-h-[80vh] overflow-hidden">
          <div class="flex justify-between items-center p-4 border-b">
            <button @click="cancelEdit" class="text-gray-400 hover:text-gray-600 text-xl">←</button>
            <h3 class="text-lg font-semibold text-gray-800">编辑梦境</h3>
            <div class="w-8"></div>
          </div>
          <div class="p-4">
            <textarea v-model="editContent" placeholder="输入梦境内容..." rows="4"
              class="w-full p-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300 resize-none mb-4"
              maxlength="500"></textarea>
            <div class="flex gap-2 mb-4 justify-between">
              <button v-for="(mood, key) in moods" :key="key" @click="editMood = key"
                :class="['mood-btn flex items-center justify-center w-12 h-12 rounded-full',
                  editMood === key ? 'bg-gray-100 ring-2 ring-blue-400' : 'hover:bg-gray-50']">
                <span class="text-2xl">{{ mood.emoji }}</span>
              </button>
            </div>
            <input type="date" v-model="editDate"
