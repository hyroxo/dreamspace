            <h3 class="text-lg font-semibold text-gray-800">解梦结果</h3>
            <button @click="showInterpretationModal = false" class="text-gray-400 hover:text-gray-600 text-2xl">×</button>
          </div>
          <div class="p-4">
            <div class="flex border-b mb-4">
              <button v-for="tab in [{id:'traditional',label:'传统解释'},{id:'psychological',label:'心理学分析'},{id:'suggestion',label:'行动建议'}]"
