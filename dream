            <button @click="showDeleteConfirm = false" class="flex-1 py-2 px-4 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors">取消</button>
            <button @click="deleteRecordHandler" class="flex-1 py-2 px-4 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors">确认删除</button>
          </div>
