            <div class="min-h-[200px] leading-relaxed text-gray-700 whitespace-pre-wrap">
              <p v-if="activeInterpretationTab === 'traditional'">{{ interpretationResult.traditional }}</p>
              <p v-else-if="activeInterpretationTab === 'psychological'">{{ interpretationResult.psychological }}</p>
              <p v-else>{{ interpretationResult.suggestion }}</p>
            </div>
          </div>
          <div class="flex gap-3 p-4 border-t">
            <button @click="regenerateInterpretation" :disabled="isGenerating"
              class="flex-1 py-2 px-4 border border-blue-500 text-blue-500 rounded-lg hover:bg-blue-50 transition-colors disabled:opacity-50">
              <span v-if="isGenerating" class="flex items-center justify-center">
                <span class="loading-spinner w-4 h-4 border-2 border-blue-500 border-t-transparent rounded-full mr-2"></span>
                重新生成中...
              </span>
              <span v-else>重新生成</span>
            </button>
            <button @click="showInterpretationModal = false" class="flex-1 py-2 px-4 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors">关闭</button>
          </div>
        </div>
      </div>
    </div>
  `
};
const CalendarPage = {
  setup() {
    const weekDays = ['日', '一', '二', '三', '四', '五', '六'];
    const currentYear = ref(new Date().getFullYear());
    const currentMonth = ref(new Date().getMonth());
    const selectedDate = ref(new Date().toISOString().split('T')[0]);
    const records = ref([]);
    const loadRecords = () => { records.value = getRecords(); };
    const calendarDays = computed(() => {
      const days = [];
      const firstDay = new Date(currentYear.value, currentMonth.value, 1);
      const lastDay = new Date(currentYear.value, currentMonth.value + 1, 0);
      const today = new Date().toISOString().split('T')[0];
      const startPadding = firstDay.getDay();
      const prevMonthLastDay = new Date(currentYear.value, currentMonth.value, 0).getDate();
      for (let i = startPadding - 1; i >= 0; i--) {
        days.push({ day: prevMonthLastDay - i, date: '', isCurrentMonth: false, hasRecord: false, mood: null });
      }
      for (let day = 1; day <= lastDay.getDate(); day++) {
        const date = new Date(currentYear.value, currentMonth.value, day);
        const dateStr = date.toISOString().split('T')[0];
        const record = records.value.find(r => r.date === dateStr);
        days.push({ day, date: dateStr, isCurrentMonth: true, isToday: dateStr === today, hasRecord: !!record, mood: record?.mood || null });
      }
      const remaining = 42 - days.length;
      for (let day = 1; day <= remaining; day++) {
        days.push({ day, date: '', isCurrentMonth: false, hasRecord: false, mood: null });
      }
      return days;
    });
    const selectedDateData = computed(() => {
      const date = new Date(selectedDate.value);
      const today = new Date().toISOString().split('T')[0];
      return { date: `${currentYear.value}年${currentMonth.value + 1}月${date.getDate()}日`, today: selectedDate.value === today };
    });
    const selectedDateRecords = computed(() => records.value.filter(r => r.date === selectedDate.value));
    const prevMonth = () => { if (currentMonth.value === 0) { currentMonth.value = 11; currentYear.value--; } else currentMonth.value--; };
    const nextMonth = () => { if (currentMonth.value === 11) { currentMonth.value = 0; currentYear.value++; } else currentMonth.value++; };
    const selectDate = (day) => { if (day.isCurrentMonth) selectedDate.value = day.date; };
    onMounted(loadRecords);
    return {
      weekDays, currentYear, currentMonth, selectedDate, calendarDays, selectedDateData, selectedDateRecords,
      prevMonth, nextMonth, selectDate, getMoodEmoji, getMoodColor, getMoodLabel
    };
  },
  template: `
    <div class="space-y-6">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-800 mb-2">梦境日历</h1>
        <p class="text-gray-500">查看每日的梦境记录</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <div class="flex items-center justify-between mb-4">
          <button @click="prevMonth" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100">←</button>
          <h2 class="text-lg font-semibold text-gray-800">{{ currentYear }}年{{ currentMonth + 1 }}月</h2>
          <button @click="nextMonth" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100">→</button>
        </div>
        <div class="grid grid-cols-7 gap-1 mb-2">
          <div v-for="day in weekDays" :key="day" class="text-center text-sm font-medium text-gray-500 py-2">{{ day }}</div>
        </div>
        <div class="grid grid-cols-7 gap-1">
          <div v-for="(day, index) in calendarDays" :key="index"
            :class="['relative aspect-square flex flex-col items-center justify-center rounded-lg cursor-pointer transition-all',
              day.isCurrentMonth ? 'hover:bg-gray-100' : 'bg-gray-50 text-gray-300',
              day.isToday ? 'ring-2 ring-blue-400 ring-inset' : '',
              selectedDate === day.date ? 'bg-blue-500 text-white' : '']"
            :style="day.hasRecord && selectedDate !== day.date ? { backgroundColor: getMoodColor(day.mood) + '30' } : {}"
            @click="selectDate(day)">
            <span class="text-sm">{{ day.day }}</span>
            <span v-if="day.hasRecord && selectedDate !== day.date" class="text-xs">{{ getMoodEmoji(day.mood) }}</span>
          </div>
        </div>
      </div>
      <div v-if="selectedDateData" class="bg-white rounded-xl shadow-sm p-4">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">
          {{ selectedDateData.date }}
          <span v-if="selectedDateData.today" class="text-sm font-normal text-gray-500 ml-2">(今天)</span>
        </h3>
        <div v-if="selectedDateRecords.length > 0" class="space-y-4">
          <div v-for="record in selectedDateRecords" :key="record.id" class="p-4 bg-gray-50 rounded-lg">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xl">{{ getMoodEmoji(record.mood) }}</span>
              <span class="text-sm text-gray-500">{{ getMoodLabel(record.mood) }}</span>
            </div>
            <p class="text-gray-800 leading-relaxed mb-3 whitespace-pre-wrap">{{ record.content }}</p>
            <div v-if="record.interpretation" class="space-y-3 mt-4 pt-4 border-t">
              <div v-if="record.interpretation.traditional" class="text-sm">
                <span class="font-medium text-blue-500">传统解释：</span>{{ record.interpretation.traditional }}
              </div>
              <div v-if="record.interpretation.psychological" class="text-sm">
                <span class="font-medium text-blue-500">心理学分析：</span>{{ record.interpretation.psychological }}
              </div>
              <div v-if="record.interpretation.suggestion" class="text-sm">
                <span class="font-medium text-blue-500">行动建议：</span>{{ record.interpretation.suggestion }}
              </div>
            </div>
          </div>
        </div>
        <div v-else class="text-center text-gray-400 py-8">当天暂无梦境记录</div>
      </div>
    </div>
  `
};
const SettingsPage = {
  setup() {
    const fileInput = ref(null);
    const showClearConfirm = ref(false);
    const puterLoggedIn = ref(false);
    const isProcessing = ref(false);
    const togglePuterLogin = async () => {
      isProcessing.value = true;
      try {
        await ensurePuter();
        if (puterLoggedIn.value) {
          try { await puter.auth.signOut(); } catch {}
          puterLoggedIn.value = false;
          showToast('已退出Puter账户');
        } else {
          try { await puter.auth.signIn(); puterLoggedIn.value = true; showToast('Puter账户登录成功'); }
          catch { showToast('Puter登录需要HTTPS环境', 'error'); }
        }
      } catch { showToast('Puter服务不可用', 'error'); }
      finally { isProcessing.value = false; }
    };
    const exportData = () => { exportToTxt(); showToast('数据导出成功'); };
    const importData = () => fileInput.value?.click();
    const handleFileImport = (event) => {
      const file = event.target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const result = importFromTxt(e.target.result);
        if (result.success) showToast(`成功导入${result.count}条记录`);
        else showToast(result.message || '导入失败', 'error');
      };
      reader.readAsText(file, 'UTF-8');
      event.target.value = '';
    };
    const confirmClearData = () => { showClearConfirm.value = true; };
    const clearData = () => { clearAllData(); showClearConfirm.value = false; showToast('所有数据已清除'); };
    return {
      fileInput, showClearConfirm, puterLoggedIn, isProcessing, togglePuterLogin,
      exportData, importData, handleFileImport, confirmClearData, clearData
    };
  },
  template: `
    <div class="space-y-6">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-800 mb-2">设置</h1>
        <p class="text-gray-500">管理你的梦境数据</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Puter账户</h2>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600">
              <span :class="puterLoggedIn ? 'text-green-500' : 'text-gray-400'">
                {{ puterLoggedIn ? '✓ 已登录' : '○ 未登录' }}
              </span>
              <span class="ml-2">Puter账户</span>
            </p>
            <p class="text-sm text-gray-400 mt-1">用于AI解梦功能（需HTTPS环境）</p>
          </div>
          <button @click="togglePuterLogin" :disabled="isProcessing"
            :class="['px-4 py-2 rounded-lg transition-colors disabled:opacity-50',
              puterLoggedIn ? 'bg-red-500 text-white hover:bg-red-600' : 'bg-blue-500 text-white hover:bg-blue-600']">
            {{ isProcessing ? '处理中...' : (puterLoggedIn ? '退出登录' : '登录') }}
          </button>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">数据管理</h2>
        <div class="space-y-3">
          <button @click="exportData" class="w-full flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
            <span class="text-gray-700">导出数据</span><span class="text-blue-500">→</span>
          </button>
          <button @click="importData" class="w-full flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
            <span class="text-gray-700">导入数据</span><span class="text-blue-500">→</span>
          </button>
          <button @click="confirmClearData" class="w-full flex items-center justify-between p-3 border border-red-200 rounded-lg hover:bg-red-50 transition-colors text-red-600">
            <span>清除所有数据</span><span>→</span>
          </button>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm p-4">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">关于</h2>
        <div class="space-y-2 text-sm text-gray-600">
          <p><strong>版本号：</strong>v1.0.0</p>
          <p><strong>开发者：</strong>产品经理助手</p>
          <p><strong>技术支持：</strong>Puter.js + DeepSeek R1</p>
          <p class="text-gray-400 mt-4">解梦日记是一款帮助你记录和解读梦境的工具。所有数据仅保存在本地浏览器中，确保隐私安全。</p>
        </div>
      </div>
      <input ref="fileInput" type="file" accept=".txt" class="hidden" @change="handleFileImport" />
      <div v-if="showClearConfirm" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl p-6 max-w-sm mx-4">
          <h3 class="text-lg font-semibold text-gray-800 mb-2">确认清除</h3>
          <p class="text-gray-600 mb-4">此操作将永久删除所有梦境数据，无法恢复。确定要继续吗？</p>
          <div class="flex gap-3">
            <button @click="showClearConfirm = false" class="flex-1 py-2 px-4 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors">取消</button>
            <button @click="clearData" class="flex-1 py-2 px-4 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors">确认清除</button>
          </div>
        </div>
      </div>
    </div>
  `
};
const App = {
  components: { HomePage, CalendarPage, SettingsPage },
  setup() {
    const currentPage = ref('home');
    const pages = { home: HomePage, calendar: CalendarPage, settings: SettingsPage };
    const tabs = [
      { id: 'home', label: '首页', icon: '🏠' },
      { id: 'calendar', label: '日历', icon: '📅' },
      { id: 'settings', label: '设置', icon: '⚙️' }
    ];
    return { currentPage, pages, tabs };
  },
  template: `
    <div class="min-h-screen bg-gray-100 pb-20">
      <main class="max-w-4xl mx-auto px-4 py-6">
        <transition name="fade" mode="out-in">
          <component :is="pages[currentPage]" :key="currentPage" />
        </transition>
      </main>
      <nav class="fixed bottom-0 left-0 right-0 bg-white shadow-lg z-50">
        <div class="max-w-4xl mx-auto flex justify-around">
          <button v-for="tab in tabs" :key="tab.id" @click="currentPage = tab.id"
            :class="['flex flex-col items-center py-2 px-4 min-w-[100px] transition-all my-1',
              currentPage === tab.id ? 'text-blue-500 bg-blue-50 rounded-full mx-2' : 'text-gray-500 hover:text-gray-700']">
            <span class="text-2xl mb-1">{{ tab.icon }}</span>
            <span class="text-xs font-medium">{{ tab.label }}</span>
          </button>
        </div>
      </nav>
    </div>
  `
};
createApp(App).mount('#app');
</script>
